# DeepSeek API Key Configuration
# Copy this file to api_key.yaml and fill in your key
# Or set the DEEPSEEK_API_KEY / ANTHROPIC_API_KEY environment variable instead

llm:
  api_key: "sk-your-deepseek-api-key-here"
  model: "deepseek-v4-flash"
  # Alternative backends:
  # backend: "deepseek"   # DeepSeek (default)
  # backend: "claude"     # Anthropic Claude (set ANTHROPIC_API_KEY)
  # backend: "ollama"     # Local Ollama (set OLLAMA_URL)
